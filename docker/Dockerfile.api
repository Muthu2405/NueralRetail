FROM python:3.12-slim

WORKDIR /app

# Install the package from the repo context
COPY pyproject.toml README.md ./
COPY src ./src
RUN pip install --no-cache-dir ".[dev]"

# Make sure the runtime dirs exist
RUN mkdir -p /app/data/processed /app/models /app/mlruns

EXPOSE 8000

# Bind to all interfaces inside the container
ENV NEURALRETAIL_API_HOST=0.0.0.0
ENV NEURALRETAIL_API_PORT=8000

CMD ["uvicorn", "neuralretail.api.main:app", "--host", "0.0.0.0", "--port", "8000"]
