FROM python:3.12-slim

WORKDIR /app

COPY pyproject.toml README.md ./
COPY src ./src
RUN pip install --no-cache-dir ".[dev]"

EXPOSE 8501

ENV NEURALRETAIL_DASHBOARD_HOST=0.0.0.0
ENV NEURALRETAIL_DASHBOARD_PORT=8501

CMD ["streamlit", "run", "src/neuralretail/dashboard/app.py", \
     "--server.port", "8501", \
     "--server.address", "0.0.0.0"]
