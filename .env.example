# NeuralRetail environment configuration
# Copy this file to `.env` and fill in real values.

# --- Paths ---
NEURALRETAIL_DATA_DIR=./data
NEURALRETAIL_RAW_DIR=./data/raw
NEURALRETAIL_PROCESSED_DIR=./data/processed
NEURALRETAIL_MODELS_DIR=./models
NEURALRETAIL_REPORT_DIR=./report

# --- MLflow ---
MLFLOW_TRACKING_URI=sqlite:///./mlruns/mlflow.db
MLFLOW_ARTIFACT_ROOT=./mlruns/artifacts
MLFLOW_EXPERIMENT_NAME=neuralretail

# --- API ---
NEURALRETAIL_API_KEY=change-me-in-prod
NEURALRETAIL_API_HOST=0.0.0.0
NEURALRETAIL_API_PORT=8000

# --- Dashboard ---
NEURALRETAIL_DASHBOARD_HOST=0.0.0.0
NEURALRETAIL_DASHBOARD_PORT=8501

# --- Feature flags ---
NEURALRETAIL_ENABLE_LSTM=false
NEURALRETAIL_ENABLE_LIGHTGBM=false
NEURALRETAIL_ENABLE_DBSCAN=false

# --- Drift monitoring ---
# Fraction of the cleaned data treated as the "reference" (oldest) window;
# the remainder is the "current" window. 0.7 = 70/30 chronological split.
NEURALRETAIL_DRIFT_REFERENCE_FRACTION=0.7

# --- Logging ---
NEURALRETAIL_LOG_LEVEL=INFO
