# NeuralRetail environment configuration
# Copy this file to `.env` and fill in real values.

# --- Paths ---
NEURALRETAIL_DATA_DIR=./data
NEURALRETAIL_RAW_DIR=./data/raw
NEURALRETAIL_PROCESSED_DIR=./data/processed
NEURALRETAIL_MODELS_DIR=./models
NEURALRETAIL_REPORT_DIR=./report

# --- MLflow ---
MLFLOW_TRACKING_URI=sqlite:///./mlruns/mlflow.db
MLFLOW_ARTIFACT_ROOT=./mlruns/artifacts
MLFLOW_EXPERIMENT_NAME=neuralretail

# --- API ---
NEURALRETAIL_API_KEY=change-me-in-prod
NEURALRETAIL_API_HOST=0.0.0.0
NEURALRETAIL_API_PORT=8000

# --- Dashboard ---
NEURALRETAIL_DASHBOARD_HOST=0.0.0.0
NEURALRETAIL_DASHBOARD_PORT=8501

# --- Feature flags ---
# LightGBM is an opt-in second model for the churn classifier; off by
# default. Set to true to add a side-by-side LightGBM training run
# logged to MLflow (does not change the production model selection).
NEURALRETAIL_ENABLE_LIGHTGBM=false
# DBSCAN is an opt-in alternative to KMeans for customer segmentation.
NEURALRETAIL_ENABLE_DBSCAN=false

# --- Prophet (demand forecasting) ---
# changepoint_prior_scale controls trend flexibility; lower = stiffer trend.
# seasonality_mode "multiplicative" matches the synthetic data's
# trend × weekly × yearly structure.
NEURALRETAIL_PROPHET_CHANGEPORT_PRIOR_SCALE=0.05
NEURALRETAIL_PROPHET_SEASONALITY_MODE=multiplicative
NEURALRETAIL_PROPHET_YEARLY_FOURIER_ORDER=10
NEURALRETAIL_PROPHET_WEEKLY_FOURIER_ORDER=3
# Holiday calendar to inject into the model. Empty list disables.
# Supported: "UK", "US", "DE" (anything Prophet knows about).
NEURALRETAIL_PROPHET_HOLIDAYS_COUNTRY=UK

# --- Drift monitoring ---
# Fraction of the cleaned data treated as the "reference" (oldest) window;
# the remainder is the "current" window. 0.7 = 70/30 chronological split.
NEURALRETAIL_DRIFT_REFERENCE_FRACTION=0.7

# --- Logging ---
NEURALRETAIL_LOG_LEVEL=INFO
